{
  "name": "peleai360",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch server/run.ts",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "server": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs server/run.ts",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node ./node_modules/tsx/dist/cli.mjs server/run.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "prisma": "5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
